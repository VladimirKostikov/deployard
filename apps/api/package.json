{
  "name": "@dpd/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "rm -f tsconfig.build.tsbuildinfo && nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run",
    "migration:run": "pnpm build && node ./node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "migration:revert": "node ./node_modules/typeorm/cli.js migration:revert -d dist/database/data-source.js",
    "migration:show": "node ./node_modules/typeorm/cli.js migration:show -d dist/database/data-source.js",
    "create-admin": "pnpm build && node dist/database/scripts/create-admin.js"
  },
  "dependencies": {
    "@dpd/shared": "workspace:*",
    "@kubernetes/client-node": "^1.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.2",
    "@nestjs/websockets": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0",
    "typeorm": "^1.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/passport-jwt": "^4.0.1",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
